{
  "command_timeout": 5,
  "templates_folder": "_template",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": false,
  "folder_templates": [
    {
      "folder": "",
      "template": ""
    }
  ],
  "enable_file_templates": true,
  "file_templates": [
    {
      "regex": "^DIARY/\\d{4}-\\d{2}-\\d{2} .+\\.md$",
      "template": "_template/Diary Card Templater.md"
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    ""
  ],
  "startup_templates": [
    "_template/templater-startup-template-view-counter.md"
  ],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [
    {
      "folder": ""
    }
  ]
}