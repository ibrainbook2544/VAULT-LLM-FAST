{
  "dateFormat": "yyyy-MM-dd HH:mm:ss",
  "enableCreateTime": true,
  "headerUpdated": "updated",
  "headerCreated": "created",
  "minMinutesBetweenSaves": 1,
  "ignoreGlobalFolder": [
    "_attachment",
