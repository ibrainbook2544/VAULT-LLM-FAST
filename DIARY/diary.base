filters:
  and:
    - file.folder == "DIARY"
    - note.type == "diary"
    - note.subtype == "card"
formulas:
  due_today: note.sr_next_review_datetime <= date(today())
  overdue_days: if(note.sr_next_review_datetime, if((now() - note.sr_next_review_datetime).days > 0, ((now() - note.sr_next_review_datetime).days).toFixed(0), 0), 0)
properties:
  note.subtype:
    displayName: 类型
  note.importance:
    displayName: 重要
  note.sr_review_count:
    displayName: 次数
  note.sr_next_review_datetime:
    displayName: 下次复习日
  formula.overdue_days:
    displayName: 逾期天数
views:
  - type: table
    name: 今日复习
    filters:
      and:
        - formula.due_today == true
    order:
      - file.name
      - subtype
      - importance
      - sr_review_count
      - sr_next_review_datetime
    sort:
      - property: importance
        direction: DESC
  - type: table
    name: 逾期
    filters:
      and:
        - note.sr_next_review_datetime < date(today())
    order:
      - file.name
      - subtype
      - importance
      - sr_next_review_datetime
      - formula.overdue_days
  - type: table
    name: 高价值低曝光
    filters:
      and:
        - note.importance >= 4
        - note.sr_review_count < 3
    order:
      - file.name
      - subtype
      - importance
      - sr_review_count
      - sr_next_review_datetime
  - type: table
    name: 新建未复习
    filters:
      and:
        - note.sr_review_count == 0
    order:
      - file.name
      - subtype
      - importance
      - file.ctime
  - type: cards
    name: 全部
    order:
      - file.name
      - subtype
      - importance
      - sr_review_count
